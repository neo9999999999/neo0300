# Streamlit Community Cloud — Secrets 템플릿
#
# 사용법:
#   1. https://share.streamlit.io 에서 앱 등록 후
#   2. App 설정 → Secrets 탭에 아래 내용 복사 + 본인 값 입력
#
# 로컬 테스트 시:
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   (실제 secrets.toml은 .gitignore에서 제외됨 — 절대 커밋 X)

# 텔레그램 봇 (선택)
TG_BOT_TOKEN = "123456:ABC-DEF..."
TG_CHAT_ID = "123456789"
